generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id           Int       @id
  name         String
  userRating   Decimal   @default(0)
  platform     Platform  @default(PC)
  status       Status    @default(WISHLIST)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cover        String?
  genres       String[]  @default([])
  rating       Int?
  release_date DateTime?
  notes        String?
}

enum Platform {
  PC
  PLAYSTATION_5
  NINTENDO_SWITCH_2
}

enum Status {
  WISHLIST
  BACKLOG
  PLAYING
  SHELVED
  COMPLETED
  DROPPED
}
